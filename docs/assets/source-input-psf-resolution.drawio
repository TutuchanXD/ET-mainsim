        <mxCell id="e_flux_chain" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#67A84B;strokeWidth=2;" edge="1" parent="1" source="frame_flux" target="detector_chain">

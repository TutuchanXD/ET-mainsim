        <mxCell id="e_explicit_resolved" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#9561C9;strokeWidth=2;" edge="1" parent="1" source="explicit" target="resolved">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
